<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Deco — Investor Pitch Deck</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --mocha: #2C1810;
  --terra: #C4714A;
  --sand: #F5EFE6;
  --cream: #FDFAF6;
  --gold: #B8924A;
  --mid: #5A3E32;
  --soft: #9A8F87;
}
html, body { width:100%; height:100%; overflow:hidden; font-family:'DM Sans',sans-serif; background:#111; }

/* SLIDE CONTAINER */
.deck { width:100%; height:100%; position:relative; }
.slide {
  position:absolute; inset:0;
  display:flex; flex-direction:column;
  opacity:0; pointer-events:none;
  transition:opacity 0.5s ease, transform 0.5s ease;
  transform:translateX(40px);
  overflow:hidden;
}
.slide.active { opacity:1; pointer-events:all; transform:translateX(0); }
.slide.prev { opacity:0; transform:translateX(-40px); }

/* NAVIGATION */
.nav-bar {
  position:fixed; bottom:2rem; left:50%; transform:translateX(-50%);
  display:flex; align-items:center; gap:1rem; z-index:100;
  background:rgba(44,24,16,0.85); backdrop-filter:blur(12px);
  padding:0.7rem 1.2rem; border-radius:3rem;
  border:1px solid rgba(196,113,74,0.3);
}
.nav-btn {
  background:none; border:1px solid rgba(253,250,246,0.2);
  color:rgba(253,250,246,0.7); width:32px; height:32px;
  border-radius:50%; cursor:pointer; font-size:0.85rem;
  display:flex; align-items:center; justify-content:center;
  transition:all 0.2s; font-family:inherit;
}
.nav-btn:hover { background:var(--terra); border-color:var(--terra); color:white; }
.slide-counter { font-size:0.78rem; color:rgba(253,250,246,0.5); min-width:50px; text-align:center; letter-spacing:0.06em; }
.lang-btn {
  background:none; border:1px solid rgba(196,113,74,0.4);
  color:var(--terra); padding:0.25rem 0.8rem; border-radius:2rem;
  font-size:0.72rem; cursor:pointer; letter-spacing:0.08em; text-transform:uppercase;
  font-family:inherit; transition:all 0.2s;
}
.lang-btn:hover { background:var(--terra); color:white; }

/* DOTS */
.dots {
  position:fixed; right:1.5rem; top:50%; transform:translateY(-50%);
  display:flex; flex-direction:column; gap:8px; z-index:100;
}
.dot {
  width:6px; height:6px; border-radius:50%;
  background:rgba(253,250,246,0.2); cursor:pointer;
  transition:all 0.25s;
}
.dot.active { background:var(--terra); transform:scale(1.4); }

/* KEYBOARD HINT */
.hint {
  position:fixed; top:1.2rem; right:1.5rem; z-index:100;
  font-size:0.68rem; color:rgba(253,250,246,0.3); letter-spacing:0.06em;
}

/* ===================== SLIDE STYLES ===================== */

/* S1 — COVER */
.s1 { background:var(--mocha); }
.s1-bg {
  position:absolute; inset:0;
  background: radial-gradient(ellipse at 70% 50%, rgba(196,113,74,0.18) 0%, transparent 65%),
              radial-gradient(ellipse at 20% 80%, rgba(196,113,74,0.08) 0%, transparent 50%);
}
.s1-grid {
  position:absolute; inset:0; opacity:0.04;
  background-image: linear-gradient(var(--terra) 1px, transparent 1px),
                    linear-gradient(90deg, var(--terra) 1px, transparent 1px);
  background-size:60px 60px;
}
.s1-content {
  position:relative; z-index:2;
  display:flex; flex-direction:column;
  justify-content:center; align-items:flex-start;
  height:100%; padding:5rem 7rem;
}
.s1-badge {
  font-size:0.72rem; letter-spacing:0.18em; text-transform:uppercase;
  color:var(--terra); border:1px solid rgba(196,113,74,0.4);
  padding:0.35rem 1rem; border-radius:2rem; margin-bottom:2.5rem;
}
.s1-logo {
  font-family:'Cormorant Garamond',serif;
  font-size:5.5rem; font-weight:300; color:var(--cream);
  line-height:1; margin-bottom:0.5rem; letter-spacing:0.04em;
}
.s1-logo span { color:var(--terra); }
.s1-tagline {
  font-family:'Cormorant Garamond',serif;
  font-size:1.6rem; font-weight:300; font-style:italic;
  color:rgba(253,250,246,0.55); margin-bottom:3rem;
}
.s1-divider { width:4rem; height:1px; background:var(--terra); margin-bottom:2rem; }
.s1-sub { font-size:0.88rem; color:rgba(253,250,246,0.35); letter-spacing:0.04em; }
.s1-year {
  position:absolute; bottom:3rem; right:7rem;
  font-family:'Cormorant Garamond',serif;
  font-size:6rem; font-weight:300; color:rgba(196,113,74,0.06);
  letter-spacing:0.1em;
}

/* S2 — PROBLEM */
.s2 { background:var(--cream); }
.s2-content { height:100%; display:grid; grid-template-columns:1fr 1fr; }
.s2-left {
  background:var(--mocha); padding:5rem;
  display:flex; flex-direction:column; justify-content:center;
}
.slide-num {
  font-family:'Cormorant Garamond',serif;
  font-size:0.72rem; letter-spacing:0.2em; text-transform:uppercase;
  margin-bottom:2rem;
}
.s2-left .slide-num { color:rgba(253,250,246,0.25); }
.slide-label {
  font-size:0.72rem; letter-spacing:0.16em; text-transform:uppercase;
  margin-bottom:0.8rem;
}
.s2-left .slide-label { color:var(--terra); }
.slide-title {
  font-family:'Cormorant Garamond',serif;
  font-size:3rem; font-weight:300; line-height:1.15; margin-bottom:2rem;
}
.s2-left .slide-title { color:var(--cream); }
.s2-right { padding:5rem; display:flex; flex-direction:column; justify-content:center; gap:2rem; }
.problem-card {
  padding:1.5rem; border-radius:0.75rem;
  border-left:3px solid var(--terra);
  background:white; box-shadow:0 2px 20px rgba(44,24,16,0.06);
}
.problem-card h4 { font-size:0.95rem; font-weight:500; margin-bottom:0.4rem; color:var(--mocha); }
.problem-card p { font-size:0.82rem; line-height:1.6; color:var(--mid); }

/* S3 — SOLUTION */
.s3 { background:var(--sand); }
.s3-content { height:100%; padding:5rem 7rem; display:flex; flex-direction:column; justify-content:center; }
.s3-header { margin-bottom:3.5rem; }
.solution-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
.solution-card {
  background:white; border-radius:1rem; padding:2rem;
  border:1px solid rgba(44,24,16,0.08);
  transition:transform 0.3s;
}
.solution-card:hover { transform:translateY(-4px); }
.sol-icon {
  width:44px; height:44px; border-radius:0.75rem;
  background:rgba(196,113,74,0.12); display:flex; align-items:center;
  justify-content:center; margin-bottom:1.2rem;
  font-size:1.2rem;
}
.solution-card h4 { font-size:1rem; font-weight:500; margin-bottom:0.5rem; color:var(--mocha); }
.solution-card p { font-size:0.82rem; line-height:1.6; color:var(--mid); }

/* S4 — MARKET */
.s4 { background:var(--mocha); }
.s4-content { height:100%; padding:5rem 7rem; display:flex; flex-direction:column; justify-content:center; }
.s4-content .slide-label { color:var(--terra); }
.s4-content .slide-title { color:var(--cream); margin-bottom:3.5rem; }
.market-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2rem; margin-bottom:3rem; }
.market-card {
  padding:2rem; border-radius:1rem;
  border:1px solid rgba(255,255,255,0.07);
  background:rgba(255,255,255,0.04);
}
.market-num {
  font-family:'Cormorant Garamond',serif;
  font-size:3rem; font-weight:300; color:var(--terra); margin-bottom:0.3rem;
}
.market-label { font-size:0.8rem; color:rgba(253,250,246,0.5); margin-bottom:0.8rem; }
.market-desc { font-size:0.78rem; line-height:1.6; color:rgba(253,250,246,0.35); }
.market-note {
  font-size:0.82rem; color:rgba(253,250,246,0.3); padding-top:1.5rem;
  border-top:1px solid rgba(255,255,255,0.06);
}
.market-note strong { color:var(--terra); }

/* S5 — PRODUCT */
.s5 { background:var(--cream); }
.s5-content { height:100%; display:grid; grid-template-columns:1fr 1.2fr; }
.s5-left { padding:5rem; display:flex; flex-direction:column; justify-content:center; }
.s5-left .slide-label { color:var(--terra); }
.s5-right {
  background:var(--mocha); position:relative; overflow:hidden;
  display:flex; align-items:center; justify-content:center; padding:3rem;
}
.screen-mock {
  background:var(--cream); border-radius:1rem; width:100%;
  max-width:320px; overflow:hidden;
  box-shadow:0 30px 80px rgba(0,0,0,0.5);
}
.screen-nav {
  background:white; padding:0.8rem 1rem;
  display:flex; justify-content:space-between; align-items:center;
  border-bottom:1px solid rgba(44,24,16,0.06);
}
.screen-logo { font-family:'Cormorant Garamond',serif; font-size:1rem; color:var(--mocha); }
.screen-logo span { color:var(--terra); }
.screen-hero { padding:1.5rem 1rem; background:var(--mocha); }
.screen-tag { font-size:0.55rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--terra); margin-bottom:0.5rem; }
.screen-h { font-family:'Cormorant Garamond',serif; font-size:1.3rem; color:var(--cream); margin-bottom:0.8rem; }
.screen-btn { background:var(--terra); color:white; font-size:0.6rem; padding:0.4rem 0.8rem; border-radius:1rem; display:inline-block; }
.screen-cards { padding:1rem; display:flex; flex-direction:column; gap:0.6rem; }
.screen-card {
  background:white; border-radius:0.5rem; padding:0.8rem;
  border:1px solid rgba(44,24,16,0.08); display:flex; gap:0.6rem;
}
.sc-avatar { width:30px; height:30px; border-radius:50%; flex-shrink:0; }
.av1 { background:linear-gradient(135deg,#C8B4A0,#A8907A); }
.av2 { background:linear-gradient(135deg,#A0B4C0,#6E8A96); }
.av3 { background:linear-gradient(135deg,#B8C4A8,#90A880); }
.sc-info { flex:1; }
.sc-name { font-size:0.65rem; font-weight:500; color:var(--mocha); }
.sc-sub { font-size:0.55rem; color:var(--soft); margin-top:1px; }
.sc-stars { font-size:0.55rem; color:var(--gold); margin-top:3px; }
.s5-features { margin-top:2.5rem; display:flex; flex-direction:column; gap:1rem; }
.feature-row { display:flex; align-items:center; gap:0.8rem; }
.feature-dot { width:8px; height:8px; border-radius:50%; background:var(--terra); flex-shrink:0; }
.feature-row span { font-size:0.85rem; color:var(--mid); }

/* S6 — BUSINESS MODEL */
.s6 { background:var(--sand); }
.s6-content { height:100%; padding:5rem 7rem; display:flex; flex-direction:column; justify-content:center; }
.s6-content .slide-label { color:var(--terra); }
.revenue-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem; margin-top:2.5rem; margin-bottom:2.5rem; }
.rev-card {
  background:var(--mocha); border-radius:1rem; padding:2.5rem;
  position:relative; overflow:hidden;
}
.rev-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:var(--terra);
}
.rev-num {
  font-family:'Cormorant Garamond',serif;
  font-size:2.8rem; font-weight:300; color:var(--terra); margin-bottom:0.3rem;
}
.rev-title { font-size:0.88rem; font-weight:500; color:var(--cream); margin-bottom:0.6rem; }
.rev-desc { font-size:0.78rem; line-height:1.6; color:rgba(253,250,246,0.45); }
.projection-row {
  display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;
  padding:1.5rem; background:white; border-radius:1rem;
  border:1px solid rgba(44,24,16,0.08);
}
.proj-item { text-align:center; }
.proj-year { font-size:0.72rem; color:var(--soft); letter-spacing:0.06em; margin-bottom:0.3rem; }
.proj-num {
  font-family:'Cormorant Garamond',serif;
  font-size:1.6rem; color:var(--mocha);
}
.proj-note { font-size:0.7rem; color:var(--terra); margin-top:0.2rem; }

/* S7 — TRACTION */
.s7 { background:var(--mocha); }
.s7-content { height:100%; padding:5rem 7rem; display:flex; flex-direction:column; justify-content:center; }
.s7-content .slide-label { color:var(--terra); }
.s7-content .slide-title { color:var(--cream); margin-bottom:3rem; }
.traction-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; margin-bottom:2.5rem; }
.traction-item {
  padding:2rem; border-radius:1rem;
  border:1px solid rgba(255,255,255,0.07);
  background:rgba(255,255,255,0.04);
}
.tr-num {
  font-family:'Cormorant Garamond',serif;
  font-size:2.5rem; font-weight:300; color:var(--terra); margin-bottom:0.3rem;
}
.tr-label { font-size:0.82rem; color:rgba(253,250,246,0.45); }
.roadmap {
  display:flex; gap:0; background:rgba(255,255,255,0.04);
  border-radius:1rem; overflow:hidden; border:1px solid rgba(255,255,255,0.06);
}
.rm-step { flex:1; padding:1.2rem 1.5rem; border-right:1px solid rgba(255,255,255,0.06); }
.rm-step:last-child { border-right:none; }
.rm-step.active { background:rgba(196,113,74,0.12); }
.rm-month { font-size:0.68rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--terra); margin-bottom:0.4rem; }
.rm-desc { font-size:0.78rem; color:rgba(253,250,246,0.4); line-height:1.5; }
.rm-step.active .rm-desc { color:rgba(253,250,246,0.7); }

/* S8 — COMPETITION */
.s8 { background:var(--cream); }
.s8-content { height:100%; padding:5rem 7rem; display:flex; flex-direction:column; justify-content:center; }
.s8-content .slide-label { color:var(--terra); }
.comp-table { width:100%; border-collapse:collapse; margin-top:2.5rem; }
.comp-table th {
  font-size:0.72rem; letter-spacing:0.1em; text-transform:uppercase;
  color:var(--soft); font-weight:400; padding:0.8rem 1.2rem; text-align:left;
  border-bottom:1px solid rgba(44,24,16,0.1);
}
.comp-table td { padding:1rem 1.2rem; font-size:0.85rem; border-bottom:1px solid rgba(44,24,16,0.06); }
.comp-table tr:last-child td { border-bottom:none; }
.comp-table tr.deco-row { background:rgba(196,113,74,0.06); }
.comp-table tr.deco-row td { font-weight:500; color:var(--mocha); }
.check { color:var(--terra); }
.cross { color:rgba(44,24,16,0.2); }
.comp-deco-label {
  display:inline-flex; align-items:center; gap:0.4rem;
}
.comp-badge {
  font-size:0.6rem; letter-spacing:0.08em; text-transform:uppercase;
  background:var(--terra); color:white; padding:0.15rem 0.5rem; border-radius:1rem;
}

/* S9 — GO TO MARKET */
.s9 { background:var(--sand); }
.s9-content { height:100%; padding:5rem 7rem; display:flex; flex-direction:column; justify-content:center; }
.s9-content .slide-label { color:var(--terra); }
.gtm-phases { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-top:2.5rem; }
.gtm-card {
  border-radius:1rem; padding:2rem; background:white;
  border:1px solid rgba(44,24,16,0.08); position:relative;
}
.phase-num {
  font-family:'Cormorant Garamond',serif;
  font-size:3rem; font-weight:300; color:rgba(44,24,16,0.06);
  position:absolute; top:1rem; right:1.2rem;
}
.gtm-phase-label { font-size:0.68rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--terra); margin-bottom:0.5rem; }
.gtm-card h4 { font-size:1rem; font-weight:500; color:var(--mocha); margin-bottom:0.8rem; }
.gtm-list { list-style:none; }
.gtm-list li { font-size:0.8rem; color:var(--mid); padding:0.35rem 0; border-bottom:1px solid rgba(44,24,16,0.05); display:flex; gap:0.5rem; }
.gtm-list li:last-child { border-bottom:none; }
.gtm-list li::before { content:'→'; color:var(--terra); flex-shrink:0; }

/* S10 — TEAM */
.s10 { background:var(--mocha); }
.s10-content { height:100%; padding:5rem 7rem; display:flex; flex-direction:column; justify-content:center; }
.s10-content .slide-label { color:var(--terra); }
.s10-content .slide-title { color:var(--cream); margin-bottom:3rem; }
.team-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem; margin-bottom:2.5rem; }
.team-card {
  border-radius:1rem; padding:2rem;
  border:1px solid rgba(255,255,255,0.07);
  background:rgba(255,255,255,0.04);
}
.team-avatar {
  width:56px; height:56px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-family:'Cormorant Garamond',serif; font-size:1.4rem; font-weight:300;
  color:white; margin-bottom:1rem;
}
.av-terra { background:var(--terra); }
.av-gold { background:var(--gold); }
.team-name { font-size:1rem; font-weight:500; color:var(--cream); margin-bottom:0.2rem; }
.team-role { font-size:0.78rem; color:var(--terra); margin-bottom:0.8rem; letter-spacing:0.04em; }
.team-bio { font-size:0.8rem; line-height:1.6; color:rgba(253,250,246,0.45); }
.team-tags { display:flex; gap:0.4rem; margin-top:0.8rem; flex-wrap:wrap; }
.team-tag { font-size:0.65rem; padding:0.2rem 0.55rem; border-radius:1rem; border:1px solid rgba(255,255,255,0.12); color:rgba(253,250,246,0.5); }
.advisor-row {
  padding:1.2rem 1.5rem; background:rgba(255,255,255,0.04);
  border-radius:0.75rem; border:1px solid rgba(255,255,255,0.06);
}
.advisor-label { font-size:0.68rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--soft); margin-bottom:0.5rem; }
.advisor-text { font-size:0.82rem; color:rgba(253,250,246,0.4); }

/* S11 — THE ASK */
.s11 { background:var(--cream); }
.s11-content { height:100%; display:grid; grid-template-columns:1fr 1fr; }
.s11-left { background:var(--mocha); padding:5rem; display:flex; flex-direction:column; justify-content:center; }
.s11-left .slide-label { color:var(--terra); }
.s11-left .slide-title { color:var(--cream); }
.ask-amount {
  font-family:'Cormorant Garamond',serif;
  font-size:4rem; font-weight:300; color:var(--terra);
  margin:1.5rem 0 0.3rem;
}
.ask-sub { font-size:0.85rem; color:rgba(253,250,246,0.35); margin-bottom:2rem; }
.ask-terms { display:flex; flex-direction:column; gap:0.8rem; }
.ask-term { font-size:0.82rem; color:rgba(253,250,246,0.5); display:flex; gap:0.6rem; }
.ask-term::before { content:'◆'; color:var(--terra); font-size:0.5rem; margin-top:4px; flex-shrink:0; }
.s11-right { padding:5rem; display:flex; flex-direction:column; justify-content:center; }
.use-title { font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--terra); margin-bottom:2rem; }
.use-items { display:flex; flex-direction:column; gap:1.2rem; }
.use-item { display:flex; align-items:center; gap:1rem; }
.use-bar-wrap { flex:1; background:var(--sand); border-radius:1rem; height:8px; overflow:hidden; }
.use-bar { height:100%; border-radius:1rem; background:var(--terra); }
.use-label { font-size:0.82rem; color:var(--mid); min-width:140px; }
.use-pct { font-size:0.82rem; color:var(--terra); font-weight:500; min-width:35px; text-align:right; }
.milestone-grid { display:grid; grid-template-columns:1fr 1fr; gap:0.8rem; margin-top:2.5rem; }
.milestone {
  padding:1rem; border-radius:0.75rem; background:var(--sand);
  border:1px solid rgba(44,24,16,0.07);
}
.ms-date { font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--terra); margin-bottom:0.3rem; }
.ms-text { font-size:0.8rem; color:var(--mocha); }

/* S12 — VISION / CLOSE */
.s12 { background:var(--mocha); }
.s12-bg {
  position:absolute; inset:0;
  background:radial-gradient(ellipse at 30% 50%, rgba(196,113,74,0.15) 0%, transparent 60%),
             radial-gradient(ellipse at 80% 80%, rgba(196,113,74,0.07) 0%, transparent 50%);
}
.s12-content {
  position:relative; z-index:2;
  height:100%; display:flex; flex-direction:column;
  align-items:center; justify-content:center; text-align:center;
  padding:5rem;
}
.s12-eyebrow { font-size:0.72rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--terra); margin-bottom:2rem; }
.s12-quote {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(2rem,4vw,3.2rem); font-weight:300; font-style:italic;
  color:var(--cream); max-width:700px; line-height:1.3; margin-bottom:3rem;
}
.s12-quote em { color:var(--terra); font-style:normal; }
.s12-divider { width:3rem; height:1px; background:rgba(196,113,74,0.4); margin:0 auto 2.5rem; }
.s12-contact { display:flex; gap:3rem; align-items:center; }
