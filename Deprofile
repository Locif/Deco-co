<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Deco — Designer Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --mocha: #2C1810;
  --mocha-mid: #5A3E32;
  --terra: #C4714A;
  --terra-light: #E8C4B0;
  --terra-pale: rgba(196,113,74,0.08);
  --gold: #B8924A;
  --sand: #F5EFE6;
  --sand-dark: #EBE0D0;
  --cream: #FDFAF6;
  --gray: #9A8F87;
  --sidebar-w: 240px;
  --success: #4A9B6F;
  --warning: #C4914A;
}

* { margin:0; padding:0; box-sizing:border-box; }
html, body { height:100%; font-family:'DM Sans',sans-serif; background:var(--sand); color:var(--mocha); }

/* ── LAYOUT ── */
.shell { display:flex; height:100vh; overflow:hidden; }

/* ── SIDEBAR ── */
.sidebar {
  width:var(--sidebar-w); height:100%;
  background:var(--mocha);
  display:flex; flex-direction:column;
  flex-shrink:0;
  position:relative; z-index:10;
}
.sidebar-logo {
  padding:2rem 1.6rem 1.5rem;
  border-bottom:1px solid rgba(255,255,255,0.07);
}
.logo-text {
  font-family:'Cormorant Garamond',serif;
  font-size:1.7rem; font-weight:300; letter-spacing:0.06em;
  color:var(--cream); text-decoration:none; display:block;
}
.logo-text span { color:var(--terra); }
.logo-badge {
  font-size:0.62rem; letter-spacing:0.12em; text-transform:uppercase;
  color:rgba(253,250,246,0.3); margin-top:0.2rem;
}

.sidebar-nav { flex:1; padding:1.2rem 0; overflow-y:auto; }
.nav-section-label {
  font-size:0.6rem; letter-spacing:0.18em; text-transform:uppercase;
  color:rgba(253,250,246,0.22); padding:0.8rem 1.6rem 0.4rem;
}
.nav-item {
  display:flex; align-items:center; gap:0.75rem;
  padding:0.7rem 1.6rem; cursor:pointer;
  transition:all 0.2s; position:relative;
  font-size:0.84rem; color:rgba(253,250,246,0.5);
  border:none; background:none; width:100%; text-align:left;
  font-family:inherit;
}
.nav-item:hover { color:rgba(253,250,246,0.85); background:rgba(255,255,255,0.04); }
.nav-item.active {
  color:var(--cream);
  background:rgba(196,113,74,0.15);
}
.nav-item.active::before {
  content:''; position:absolute; left:0; top:0; bottom:0;
  width:3px; background:var(--terra); border-radius:0 2px 2px 0;
}
.nav-icon { font-size:1rem; width:18px; text-align:center; }
.nav-badge {
  margin-left:auto; background:var(--terra);
  color:white; font-size:0.62rem; font-weight:500;
  padding:0.15rem 0.5rem; border-radius:1rem; min-width:1.2rem;
  text-align:center;
}

.sidebar-user {
  padding:1.2rem 1.6rem;
  border-top:1px solid rgba(255,255,255,0.07);
  display:flex; align-items:center; gap:0.8rem;
}
.user-avatar {
  width:36px; height:36px; border-radius:50%;
  background:var(--terra); display:flex; align-items:center;
  justify-content:center; font-family:'Cormorant Garamond',serif;
  font-size:1rem; color:white; flex-shrink:0;
}
.user-name { font-size:0.82rem; color:var(--cream); font-weight:500; }
.user-role { font-size:0.7rem; color:rgba(253,250,246,0.35); }
.user-status {
  margin-left:auto; width:8px; height:8px;
  background:var(--success); border-radius:50%; flex-shrink:0;
}

/* ── MAIN ── */
.main { flex:1; display:flex; flex-direction:column; overflow:hidden; }

/* ── TOPBAR ── */
.topbar {
  background:var(--cream); border-bottom:1px solid var(--sand-dark);
  padding:0 2.5rem; height:60px;
  display:flex; align-items:center; justify-content:space-between;
  flex-shrink:0;
}
.page-title {
  font-family:'Cormorant Garamond',serif;
  font-size:1.3rem; font-weight:300; color:var(--mocha);
}
.topbar-right { display:flex; align-items:center; gap:1rem; }
.topbar-btn {
  background:none; border:1px solid var(--sand-dark);
  color:var(--mocha-mid); padding:0.45rem 1rem; border-radius:2rem;
  font-size:0.78rem; cursor:pointer; font-family:inherit;
  transition:all 0.2s; display:flex; align-items:center; gap:0.4rem;
}
.topbar-btn:hover { border-color:var(--terra); color:var(--terra); }
.topbar-btn.primary {
  background:var(--terra); color:white; border-color:var(--terra);
}
.topbar-btn.primary:hover { background:var(--mocha); border-color:var(--mocha); }
.notif-btn {
  position:relative; background:none; border:none; cursor:pointer;
  color:var(--mocha-mid); font-size:1.1rem; padding:0.3rem;
}
.notif-dot {
  position:absolute; top:2px; right:2px;
  width:7px; height:7px; background:var(--terra); border-radius:50%;
  border:2px solid var(--cream);
}

/* ── CONTENT ── */
.content { flex:1; overflow-y:auto; padding:2rem 2.5rem; }

/* ── PANELS (tabs) ── */
.panel { display:none; }
.panel.active { display:block; }

/* ══ OVERVIEW PANEL ══ */

/* Greeting */
.greeting { margin-bottom:2rem; }
.greeting h2 {
  font-family:'Cormorant Garamond',serif;
  font-size:2rem; font-weight:300; color:var(--mocha);
}
.greeting p { font-size:0.88rem; color:var(--gray); margin-top:0.3rem; }

/* Stat cards */
.stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:1.2rem; margin-bottom:2rem; }
.stat-card {
  background:var(--cream); border-radius:1rem;
  padding:1.4rem 1.5rem;
  border:1px solid var(--sand-dark);
  position:relative; overflow:hidden;
}
.stat-card::after {
  content:''; position:absolute;
  bottom:-20px; right:-20px;
  width:80px; height:80px; border-radius:50%;
  background:var(--terra-pale);
}
.stat-label { font-size:0.72rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--gray); margin-bottom:0.6rem; }
.stat-value {
  font-family:'Cormorant Garamond',serif;
  font-size:2.2rem; font-weight:300; color:var(--mocha); line-height:1;
}
.stat-value.terra { color:var(--terra); }
.stat-delta {
  font-size:0.72rem; margin-top:0.4rem;
  display:flex; align-items:center; gap:0.3rem;
}
.delta-up { color:var(--success); }
.delta-down { color:#C44A4A; }
.stat-icon { font-size:1.1rem; margin-bottom:0.5rem; opacity:0.5; }

/* Two col layout */
.two-col { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; margin-bottom:1.5rem; }
.three-col { display:grid; grid-template-columns:2fr 1fr; gap:1.5rem; margin-bottom:1.5rem; }

/* Card base */
.card {
  background:var(--cream); border-radius:1rem;
  border:1px solid var(--sand-dark); overflow:hidden;
}
.card-header {
  padding:1.2rem 1.5rem;
  border-bottom:1px solid var(--sand-dark);
  display:flex; align-items:center; justify-content:space-between;
}
.card-title {
  font-family:'Cormorant Garamond',serif;
  font-size:1.1rem; font-weight:300; color:var(--mocha);
}
.card-action {
  font-size:0.75rem; color:var(--terra); cursor:pointer;
  text-decoration:none; border-bottom:1px solid transparent;
  transition:border-color 0.2s;
}
.card-action:hover { border-color:var(--terra); }
.card-body { padding:1.5rem; }

/* Project list items */
.project-item {
  display:flex; align-items:flex-start; gap:1rem;
  padding:0.9rem 0; border-bottom:1px solid var(--sand);
}
.project-item:last-child { border-bottom:none; padding-bottom:0; }
.proj-icon {
  width:36px; height:36px; border-radius:0.6rem;
  display:flex; align-items:center; justify-content:center;
  font-size:0.9rem; flex-shrink:0; margin-top:2px;
}
.proj-icon.apt { background:rgba(196,113,74,0.12); }
.proj-icon.villa { background:rgba(184,146,74,0.12); }
.proj-icon.cafe { background:rgba(74,155,111,0.12); }
.proj-icon.office { background:rgba(100,120,180,0.12); }
.proj-info { flex:1; min-width:0; }
.proj-name { font-size:0.88rem; font-weight:500; color:var(--mocha); margin-bottom:0.2rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.proj-meta { font-size:0.75rem; color:var(--gray); }
.proj-status {
  font-size:0.68rem; letter-spacing:0.06em; text-transform:uppercase;
  padding:0.2rem 0.6rem; border-radius:1rem; font-weight:500; flex-shrink:0;
}
.status-active { background:rgba(74,155,111,0.12); color:var(--success); }
.status-review { background:rgba(196,113,74,0.12); color:var(--terra); }
.status-pending { background:rgba(154,143,135,0.12); color:var(--gray); }

/* Milestone progress */
.milestone-bar {
  height:4px; background:var(--sand-dark); border-radius:2px;
  margin-top:0.5rem; overflow:hidden;
}
.milestone-fill { height:100%; background:var(--terra); border-radius:2px; transition:width 0.5s ease; }

/* Earnings mini-chart (CSS bars) */
.mini-chart { display:flex; align-items:flex-end; gap:6px; height:60px; margin-bottom:0.5rem; }
.bar-wrap { flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; }
.bar {
  width:100%; background:var(--terra-pale); border-radius:3px 3px 0 0;
  transition:height 0.4s ease;
  position:relative; cursor:pointer;
}
.bar.active-bar { background:var(--terra); }
.bar:hover { background:var(--terra); opacity:0.8; }
.bar-label { font-size:0.6rem; color:var(--gray); }

/* Quick actions */
.quick-actions { display:grid; grid-template-columns:1fr 1fr; gap:0.8rem; }
.qa-btn {
  display:flex; align-items:center; gap:0.7rem;
  padding:0.9rem 1rem; border-radius:0.75rem;
  border:1px solid var(--sand-dark); background:var(--sand);
  cursor:pointer; transition:all 0.2s; font-family:inherit;
  font-size:0.82rem; color:var(--mocha); text-align:left;
}
.qa-btn:hover { border-color:var(--terra); background:var(--terra-pale); }
.qa-icon { font-size:1.1rem; }

/* Profile completeness */
.completeness { margin-bottom:1.5rem; }
.completeness-bar { height:6px; background:var(--sand-dark); border-radius:3px; overflow:hidden; margin:0.5rem 0; }
.completeness-fill { height:100%; background:linear-gradient(90deg, var(--terra), var(--gold)); border-radius:3px; width:72%; }
.completeness-items { display:flex; flex-direction:column; gap:0.5rem; }
.ci {
  display:flex; align-items:center; gap:0.6rem;
  font-size:0.78rem; color:var(--mocha-mid);
}
.ci-check { color:var(--success); font-size:0.75rem; }
.ci-x { color:var(--gray); font-size:0.75rem; }

/* ══ PROPOSALS PANEL ══ */
.filter-row {
  display:flex; align-items:center; gap:0.8rem; margin-bottom:1.5rem; flex-wrap:wrap;
}
.filter-chip {
  padding:0.4rem 1rem; border-radius:2rem;
  border:1px solid var(--sand-dark); background:var(--cream);
  font-size:0.78rem; color:var(--mocha-mid); cursor:pointer;
  transition:all 0.2s; font-family:inherit;
}
.filter-chip:hover, .filter-chip.active {
  background:var(--mocha); color:var(--cream); border-color:var(--mocha);
}
.filter-chip.terra.active { background:var(--terra); border-color:var(--terra); color:white; }
.search-small {
  display:flex; align-items:center; gap:0.5rem;
  background:var(--cream); border:1px solid var(--sand-dark);
  border-radius:2rem; padding:0.4rem 0.9rem;
  margin-left:auto;
}
.search-small input {
  border:none; outline:none; font-family:inherit;
  font-size:0.8rem; color:var(--mocha); background:none; width:160px;
}
.search-small input::placeholder { color:var(--gray); }

/* Open project cards */
.open-projects-grid { display:flex; flex-direction:column; gap:1.2rem; }
.open-project-card {
  background:var(--cream); border-radius:1rem;
  border:1px solid var(--sand-dark);
  padding:1.5rem; transition:all 0.25s; cursor:pointer;
}
.open-project-card:hover {
  border-color:rgba(196,113,74,0.4);
  box-shadow:0 8px 30px rgba(44,24,16,0.08);
  transform:translateY(-1px);
}
.op-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:0.8rem; }
.op-type {
  font-size:0.68rem; letter-spacing:0.1em; text-transform:uppercase;
  color:var(--terra); background:var(--terra-pale);
  padding:0.22rem 0.7rem; border-radius:1rem;
}
.op-budget {
  font-family:'Cormorant Garamond',serif;
  font-size:1.4rem; font-weight:300; color:var(--mocha);
}
.op-title { font-size:1rem; font-weight:500; margin-bottom:0.5rem; color:var(--mocha); }
.op-desc { font-size:0.82rem; line-height:1.6; color:var(--mocha-mid); margin-bottom:1rem; }
.op-footer { display:flex; align-items:center; justify-content:space-between; }
.op-meta { display:flex; align-items:center; gap:1rem; }
.op-location { font-size:0.75rem; color:var(--gray); }
.op-bids { font-size:0.75rem; color:var(--terra); }
.op-match {
  font-size:0.72rem; letter-spacing:0.06em;
  background:rgba(74,155,111,0.1); color:var(--success);
  padding:0.2rem 0.7rem; border-radius:1rem;
}
.bid-btn {
  background:var(--mocha); color:white;
  border:none; padding:0.5rem 1.3rem; border-radius:2rem;
  font-size:0.78rem; cursor:pointer; font-family:inherit; transition:all 0.2s;
}
.bid-btn:hover { background:var(--terra); }

/* My proposals */
.my-proposals-list { display:flex; flex-direction:column; gap:0.8rem; margin-top:1.5rem; }
.mp-card {
  background:var(--cream); border-radius:0.75rem;
  border:1px solid var(--sand-dark);
  padding:1.2rem 1.5rem;
  display:flex; align-items:center; gap:1.2rem;
}
.mp-color { width:4px; height:40px; border-radius:2px; flex-shrink:0; }
.mp-info { flex:1; }
.mp-title { font-size:0.9rem; font-weight:500; color:var(--mocha); }
.mp-sub { font-size:0.75rem; color:var(--gray); margin-top:0.2rem; }
.mp-date { font-size:0.72rem; color:var(--gray); text-align:right; }
.mp-amount { font-family:'Cormorant Garamond',serif; font-size:1.1rem; color:var(--terra); }

/* Proposal form modal */
.modal-overlay {
  position:fixed; inset:0; z-index:200;
  background:rgba(44,24,16,0.55); backdrop-filter:blur(6px);
  display:flex; align-items:center; justify-content:center; padding:1.5rem;
  opacity:0; pointer-events:none; transition:opacity 0.3s;
}
.modal-overlay.open { opacity:1; pointer-events:all; }
.modal {
  background:var(--cream); border-radius:1.5rem;
  width:100%; max-width:600px; max-height:90vh; overflow-y:auto;
  transform:translateY(20px) scale(0.98);
  transition:transform 0.3s cubic-bezier(.22,.68,0,1.2);
}
.modal-overlay.open .modal { transform:translateY(0) scale(1); }
.modal-header {
  padding:1.5rem 2rem; border-bottom:1px solid var(--sand-dark);
  display:flex; align-items:center; justify-content:space-between;
}
.modal-title {
  font-family:'Cormorant Garamond',serif;
  font-size:1.4rem; font-weight:300;
}
.modal-close {
  background:none; border:none; cursor:pointer;
  color:var(--gray); font-size:1.1rem; transition:color 0.2s;
}
.modal-close:hover { color:var(--mocha); }
.modal-body { padding:2rem; display:flex; flex-direction:column; gap:1.2rem; }
.form-group { display:flex; flex-direction:column; gap:0.4rem; }
.form-label { font-size:0.75rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--mocha-mid); }
.form-input, .form-textarea, .form-select {
  background:var(--sand); border:1px solid var(--sand-dark);
  border-radius:0.6rem; padding:0.75rem 1rem;
  font-family:inherit; font-size:0.88rem; color:var(--mocha);
  outline:none; transition:border-color 0.2s;
}
.form-input:focus, .form-textarea:focus, .form-select:focus {
  border-color:var(--terra);
}
.form-textarea { resize:vertical; min-height:100px; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.modal-footer {
  padding:1.5rem 2rem; border-top:1px solid var(--sand-dark);
  display:flex; justify-content:flex-end; gap:0.8rem;
}
.btn-cancel {
  background:none; border:1px solid var(--sand-dark);
  color:var(--mocha-mid); padding:0.65rem 1.5rem; border-radius:2rem;
  font-size:0.84rem; cursor:pointer; font-family:inherit; transition:all 0.2s;
}
.btn-cancel:hover { border-color:var(--mocha); color:var(--mocha); }
.btn-submit {
  background:var(--terra); color:white;
  border:none; padding:0.65rem 1.8rem; border-radius:2rem;
  font-size:0.84rem; cursor:pointer; font-family:inherit; transition:all 0.2s;
}
.btn-submit:hover { background:var(--mocha); }

/* ══ PROJECTS PANEL ══ */
.projects-board { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
.proj-col-title {
  font-size:0.7rem; letter-spacing:0.14em; text-transform:uppercase;
  color:var(--gray); margin-bottom:1rem;
  display:flex; align-items:center; gap:0.5rem;
}
.proj-col-count {
  background:var(--sand-dark); color:var(--mocha-mid);
  font-size:0.65rem; padding:0.1rem 0.5rem; border-radius:1rem;
}
.proj-card {
  background:var(--cream); border-radius:1rem;
  border:1px solid var(--sand-dark); padding:1.3rem;
  margin-bottom:1rem; cursor:pointer; transition:all 0.25s;
}
.proj-card:hover {
  border-color:rgba(196,113,74,0.35);
  box-shadow:0 6px 24px rgba(44,24,16,0.07);
}
.proj-card-type {
  font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase;
  color:var(--terra); margin-bottom:0.6rem;
}
.proj-card-title { font-size:0.9rem; font-weight:500; color:var(--mocha); margin-bottom:0.4rem; }
.proj-card-client { font-size:0.75rem; color:var(--gray); margin-bottom:1rem; }
.proj-card-budget {
  font-family:'Cormorant Garamond',serif;
  font-size:1.1rem; color:var(--mocha); margin-bottom:0.8rem;
}
.proj-card-progress { margin-bottom:0.8rem; }
.prog-label { display:flex; justify-content:space-between; font-size:0.72rem; color:var(--gray); margin-bottom:0.3rem; }
.prog-bar { height:3px; background:var(--sand-dark); border-radius:2px; overflow:hidden; }
.prog-fill { height:100%; background:var(--terra); border-radius:2px; }
.proj-card-footer {
  display:flex; align-items:center; justify-content:space-between;
  font-size:0.72rem; color:var(--gray);
}
.proj-card-due { display:flex; align-items:center; gap:0.3rem; }
.milestone-chips { display:flex; gap:0.3rem; flex-wrap:wrap; margin-top:0.6rem; }
.ms-chip {
  font-size:0.62rem; padding:0.15rem 0.5rem; border-radius:1rem;
}
.ms-done { background:rgba(74,155,111,0.12); color:var(--success); }
.ms-active { background:rgba(196,113,74,0.12); color:var(--terra); }
.ms-todo { background:var(--sand-dark); color:var(--gray); }

/* ══ PROFILE PANEL ══ */
.profile-edit-grid { display:grid; grid-template-columns:1fr 1.6fr; gap:1.5rem; }
.profile-preview-card {
  background:var(--mocha); border-radius:1rem; overflow:hidden;
}
.profile-preview-cover {
  height:120px;
  background:linear-gradient(135deg,#C8B4A0 0%,#A8907A 100%);
  position:relative;
}
.profile-preview-avatar {
  width:64px; height:64px; border-radius:50%;
  background:var(--terra); border:3px solid var(--mocha);
  display:flex; align-items:center; justify-content:center;
  font-family:'Cormorant Garamond',serif; font-size:1.4rem; color:white;
  position:absolute; bottom:-32px; left:1.5rem;
}
.profile-preview-body { padding:2.5rem 1.5rem 1.5rem; color:var(--cream); }
.profile-preview-name { font-family:'Cormorant Garamond',serif; font-size:1.3rem; font-weight:300; margin-bottom:0.2rem; }
.profile-preview-spec { font-size:0.78rem; color:rgba(253,250,246,0.5); margin-bottom:1rem; }
.profile-preview-tags { display:flex; flex-wrap:wrap; gap:0.4rem; }
.preview-tag {
  font-size:0.68rem; padding:0.2rem 0.6rem; border-radius:1rem;
  border:1px solid rgba(253,250,246,0.15); color:rgba(253,250,246,0.6);
}
.profile-preview-stats {
  display:grid; grid-template-columns:1fr 1fr;
  gap:0.8rem; margin-top:1.2rem; padding-top:1rem;
  border-top:1px solid rgba(255,255,255,0.07);
}
.pp-stat-num { font-family:'Cormorant Garamond',serif; font-size:1.3rem; color:var(--terra); }
.pp-stat-label { font-size:0.65rem; color:rgba(253,250,246,0.35); }

.section-divider {
  font-size:0.7rem; letter-spacing:0.14em; text-transform:uppercase;
  color:var(--gray); margin-bottom:1rem; margin-top:0.5rem;
  padding-bottom:0.5rem; border-bottom:1px solid var(--sand-dark);
}
.tag-input-area { display:flex; flex-wrap:wrap; gap:0.4rem; padding:0.6rem 0.8rem; background:var(--sand); border:1px solid var(--sand-dark); border-radius:0.6rem; min-height:44px; cursor:text; }
.added-tag {
  display:flex; align-items:center; gap:0.3rem;
  background:var(--terra-pale); border:1px solid rgba(196,113,74,0.2);
  color:var(--terra); font-size:0.75rem; padding:0.15rem 0.6rem; border-radius:1rem;
}
.added-tag button { background:none; border:none; cursor:pointer; color:var(--terra); font-size:0.75rem; padding:0; line-height:1; }
.tag-input { border:none; outline:none; background:none; font-family:inherit; font-size:0.82rem; color:var(--mocha); min-width:80px; }

/* ══ EARNINGS PANEL ══ */
.earnings-header-row { display:grid; grid-template-columns:repeat(3,1fr); gap:1.2rem; margin-bottom:1.5rem; }
.earn-card {
  background:var(--cream); border-radius:1rem; border:1px solid var(--sand-dark);
  padding:1.4rem; text-align:center;
}
.earn-card.highlight { background:var(--mocha); border-color:var(--mocha); }
.earn-label { font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--gray); margin-bottom:0.4rem; }
.earn-card.highlight .earn-label { color:rgba(253,250,246,0.4); }
.earn-value { font-family:'Cormorant Garamond',serif; font-size:2rem; font-weight:300; color:var(--mocha); }
.earn-card.highlight .earn-value { color:var(--terra); }
.earn-sub { font-size:0.72rem; color:var(--gray); margin-top:0.2rem; }
.earn-card.highlight .earn-sub { color:rgba(253,250,246,0.3); }

/* Chart area */
.chart-area {
  background:var(--cream); border-radius:1rem; border:1px solid var(--sand-dark);
  padding:1.5rem; margin-bottom:1.5rem;
}
.big-chart { display:flex; align-items:flex-end; gap:10px; height:120px; margin:1.5rem 0 0.5rem; }
.bc-bar {
  flex:1; border-radius:4px 4px 0 0;
  background:var(--sand-dark); transition:background 0.2s; cursor:pointer;
  position:relative;
}
.bc-bar:hover { background:var(--terra-light); }
.bc-bar.curr { background:var(--terra); }
.bc-labels { display:flex; gap:10px; }
.bc-label { flex:1; text-align:center; font-size:0.62rem; color:var(--gray); }

/* Transaction list */
.tx-list { display:flex; flex-direction:column; gap:0; }
.tx-item {
  display:flex; align-items:center; gap:1rem;
  padding:0.9rem 0; border-bottom:1px solid var(--sand);
}
.tx-item:last-child { border-bottom:none; }
.tx-icon {
  width:34px; height:34px; border-radius:0.6rem;
  display:flex; align-items:center; justify-content:center;
  font-size:0.85rem; flex-shrink:0;
}
.tx-in { background:rgba(74,155,111,0.1); }
.tx-out { background:rgba(196,113,74,0.1); }
.tx-info { flex:1; }
.tx-name { font-size:0.85rem; font-weight:500; color:var(--mocha); }
.tx-date { font-size:0.72rem; color:var(--gray); }
.tx-amount { font-family:'Cormorant Garamond',serif; font-size:1.1rem; }
.tx-amount.income { color:var(--success); }
.tx-amount.pending { color:var(--warning); }

/* ── Toast ── */
.toast {
  position:fixed; bottom:2rem; right:2rem; z-index:300;
  background:var(--mocha); color:var(--cream);
  padding:0.8rem 1.4rem; border-radius:0.75rem;
  font-size:0.84rem; display:flex; align-items:center; gap:0.6rem;
  transform:translateY(10px); opacity:0;
  transition:all 0.3s; pointer-events:none;
  box-shadow:0 8px 30px rgba(44,24,16,0.2);
}
.toast.show { opacity:1; transform:translateY(0); }
.toast-icon { color:var(--terra); }

/* ── Responsive ── */
@media (max-width:900px) {
  .sidebar { width:60px; }
  .sidebar-logo, .nav-section-label, .user-name, .user-role, .logo-badge { display:none; }
  .nav-item { padding:0.8rem; justify-content:center; }
